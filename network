/* ─── Helpers ─────────────────────────────────────────────────────────────── */
function Stars({ r }) {
  return (
    <span style={{ color:BRAND.green,fontSize:12,letterSpacing:1 }}>
      {"★".repeat(Math.floor(r))}{"☆".repeat(5-Math.floor(r))}
      <span style={{ color:BRAND.gray,marginLeft:4,fontSize:11 }}>{r}</span>
    </span>
  );
}

function SpeedLines({ count=4 }) {
  return Array.from({length:count}).map((_,i) => (
    <div key={i} className="speed-line" style={{ top:`${15+i*25}%`,left:`${10+(i%2)*5}%`,width:`${30+i*8}px`,animationDelay:`${i*0.25}s`,opacity:0.5 }} />
  ));
}

function PhotoCard({ type, label, height=180, showOverlay=true }) {
  const Component = PHOTO_COMPONENTS[type] || PHOTO_COMPONENTS.garage;
  return (
    <div className="photo-frame" style={{ position:"relative",borderRadius:8,overflow:"hidden",border:`2px solid ${BRAND.blackTint}`,height,cursor:"pointer" }}>
      <Component />
      {showOverlay && label && (
        <div style={{ position:"absolute",bottom:0,left:0,right:0,background:"linear-gradient(transparent, rgba(0,0,0,0.92))",padding:"24px 14px 12px" }}>
          <div className="osw" style={{ fontSize:11,color:BRAND.green,fontWeight:700,letterSpacing:.8,textTransform:"uppercase" }}>{label}</div>
        </div>
      )}
    </div>
  );
}

/* ─── Booking Modal ───────────────────────────────────────────────────────── */
function BookingModal({ site, onClose }) {
  const [step, setStep] = useState(1);
  const [items, setItems] = useState([]);
  const [date, setDate] = useState("");
  const [addr, setAddr] = useState("");
  const [loading, setLoad] = useState(false);
  const [done, setDone] = useState(false);
  const ITEMS = ["Furniture","Appliances","Yard Waste","Mattress","Electronics","Construction","Hot Tub / Shed","Full Cleanout"];
  const toggle = i => setItems(p => p.includes(i) ? p.filter(x=>x!==i) : [...p,i]);
  const submit = () => { setLoad(true); setTimeout(()=>{ setLoad(false); setDone(true); }, 1500); };
  const inp = { background:BRAND.black,border:`1.5px solid ${BRAND.blackTint}`,color:BRAND.white,borderRadius:4,padding:"11px 13px",fontSize:13,width:"100%" };

  return (
    <div onClick={e => e.target===e.currentTarget && onClose()} style={{ position:"fixed",inset:0,background:"rgba(0,0,0,.92)",backdropFilter:"blur(10px)",zIndex:500,display:"flex",alignItems:"center",justifyContent:"center",padding:16 }}>
      <div className="fu" style={{ background:BRAND.blackSoft,border:`2px solid ${BRAND.green}`,borderRadius:10,width:"100%",maxWidth:460,overflow:"hidden",boxShadow:`0 30px 90px ${BRAND.green}33` }}>
        <div style={{ background:`linear-gradient(135deg, ${BRAND.green}, ${BRAND.greenDark})`,padding:"18px 22px",borderBottom:`3px solid ${BRAND.black}`,position:"relative",overflow:"hidden" }}>
          <SpeedLines count={3} />
          <div style={{ display:"flex",justifyContent:"space-between",alignItems:"center",position:"relative" }}>
            <div>
              <div className="anton" style={{ fontSize:22,color:BRAND.black,lineHeight:1 }}>BOOK PICKUP</div>
              <div className="osw" style={{ fontSize:11,color:BRAND.black,marginTop:4,letterSpacing:1.5,fontWeight:600 }}>{site.city.toUpperCase()}, BC</div>
            </div>
            <button onClick={onClose} style={{ background:BRAND.black,border:"none",color:BRAND.green,width:30,height:30,borderRadius:4,cursor:"pointer",fontSize:14,fontWeight:700 }}>✕</button>
          </div>
          <div style={{ display:"flex",gap:6,marginTop:14,position:"relative" }}>
            {[1,2,3].map(s => <div key={s} style={{ flex:1,height:4,borderRadius:2,background:s<=step?BRAND.black:`${BRAND.black}55`,transition:"background .2s" }} />)}
          </div>
        </div>
        <div style={{ padding:24 }}>
          {done ? (
            <div className="fi" style={{ textAlign:"center",padding:"20px 0" }}>
              <div style={{ fontSize:54,marginBottom:8 }}>♻️</div>
              <div className="anton" style={{ fontSize:24,color:BRAND.green }}>BOOKED!</div>
              <div style={{ fontSize:13,color:BRAND.gray,marginTop:10,lineHeight:1.6 }}>
                Your crew in <span style={{ color:BRAND.white,fontWeight:700 }}>{site.city}</span> will confirm shortly.<br/>
                Job ID: <span style={{ color:BRAND.green,fontWeight:700 }}>#RJR-{3000+Math.floor(Math.random()*900)}</span>
              </div>
              <button onClick={onClose} className="osw" style={{ marginTop:20,padding:"11px 30px",background:BRAND.green,border:"none",borderRadius:4,color:BRAND.black,fontWeight:700,fontSize:13,cursor:"pointer",letterSpacing:1,textTransform:"uppercase" }}>Done</button>
            </div>
          ) : step===1 ? (
            <>
              <div className="osw" style={{ fontSize:11,color:BRAND.grayDark,textTransform:"uppercase",letterSpacing:1.5,marginBottom:12,fontWeight:600 }}>What's going?</div>
              <div style={{ display:"grid",gridTemplateColumns:"1fr 1fr",gap:7 }}>
                {ITEMS.map(i => (
                  <button key={i} onClick={()=>toggle(i)} className="osw" style={{ background:items.includes(i)?BRAND.green:BRAND.black,border:`1.5px solid ${items.includes(i)?BRAND.green:BRAND.blackTint}`,borderRadius:4,padding:"10px 12px",cursor:"pointer",color:items.includes(i)?BRAND.black:BRAND.gray,fontSize:12,fontWeight:600,textAlign:"left",transition:"all .14s",letterSpacing:.3 }}>{i}</button>
                ))}
              </div>
              <button disabled={!items.length} onClick={()=>setStep(2)} className="osw" style={{ marginTop:16,width:"100%",padding:13,background:items.length?BRAND.green:BRAND.blackTint,border:"none",borderRadius:4,color:items.length?BRAND.black:BRAND.grayDark,fontWeight:700,fontSize:14,cursor:items.length?"pointer":"not-allowed",letterSpacing:1.2,textTransform:"uppercase" }}>Next →</button>
            </>
          ) : step===2 ? (
            <>
              <div style={{ display:"flex",flexDirection:"column",gap:14 }}>
                <div><div className="osw" style={{ fontSize:11,color:BRAND.grayDark,textTransform:"uppercase",letterSpacing:1.5,marginBottom:6,fontWeight:600 }}>Pickup Date</div>
                  <input type="date" value={date} onChange={e=>setDate(e.target.value)} style={inp} /></div>
                <div><div className="osw" style={{ fontSize:11,color:BRAND.grayDark,textTransform:"uppercase",letterSpacing:1.5,marginBottom:6,fontWeight:600 }}>Address</div>
                  <input type="text" value={addr} onChange={e=>setAddr(e.target.value)} placeholder={`Your address in ${site.city}, BC`} style={inp} /></div>
              </div>
              <div style={{ display:"flex",gap:8,marginTop:18 }}>
                <button onClick={()=>setStep(1)} className="osw" style={{ flex:1,padding:12,background:"transparent",border:`1.5px solid ${BRAND.blackTint}`,borderRadius:4,color:BRAND.gray,fontSize:12,fontWeight:600,cursor:"pointer",letterSpacing:.5,textTransform:"uppercase" }}>← Back</button>
                <button disabled={!date||!addr} onClick={()=>setStep(3)} className="osw" style={{ flex:2,padding:12,background:(date&&addr)?BRAND.green:BRAND.blackTint,border:"none",borderRadius:4,color:(date&&addr)?BRAND.black:BRAND.grayDark,fontWeight:700,fontSize:14,cursor:(date&&addr)?"pointer":"not-allowed",letterSpacing:1,textTransform:"uppercase" }}>Review →</button>
              </div>
            </>
          ) : (
            <>
              <div style={{ background:BRAND.black,borderRadius:6,padding:"16px 18px",marginBottom:14,border:`1px solid ${BRAND.blackTint}` }}>
                {[["City",site.city],["Items",items.join(", ")],["Date",date],["Address",addr],["Est. Price",site.crews[0].price]].map(([k,v]) => (
                  <div key={k} style={{ display:"flex",justifyContent:"space-between",padding:"7px 0",borderBottom:`1px solid ${BRAND.blackTint}` }}>
                    <span className="osw" style={{ fontSize:11,color:BRAND.grayDark,textTransform:"uppercase",letterSpacing:1,fontWeight:600 }}>{k}</span>
                    <span style={{ fontSize:12,color:BRAND.white,maxWidth:"60%",textAlign:"right",fontWeight:500 }}>{v}</span>
                  </div>
                ))}
              </div>
              <div style={{ display:"flex",gap:8 }}>
                <button onClick={()=>setStep(2)} className="osw" style={{ flex:1,padding:12,background:"transparent",border:`1.5px solid ${BRAND.blackTint}`,borderRadius:4,color:BRAND.gray,fontSize:12,fontWeight:600,cursor:"pointer",letterSpacing:.5,textTransform:"uppercase" }}>← Edit</button>
                <button onClick={submit} className="osw" style={{ flex:2,padding:12,background:BRAND.green,border:"none",borderRadius:4,color:BRAND.black,fontWeight:700,fontSize:14,cursor:"pointer",display:"flex",alignItems:"center",justifyContent:"center",gap:8,letterSpacing:1,textTransform:"uppercase" }}>
                  {loading ? <span style={{ width:16,height:16,border:`2.5px solid ${BRAND.black}`,borderTopColor:"transparent",borderRadius:"50%",animation:"spin .7s linear infinite",display:"inline-block" }} /> : "Confirm ✓"}
                </button>
              </div>
            </>
          )}
        </div>
      </div>
    </div>
  );
}

