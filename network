  ],
};

export default function App() {
  const [activeSite, setActiveSite] = useState(null);
  const [showMain, setShowMain] = useState(false);
  const [mounted, setMounted] = useState(false);
  useEffect(()=>{ setTimeout(()=>setMounted(true), 80); }, []);

  let screen;
  if (showMain) screen = <CitySite site={MAIN_SITE} isMain={true} onBack={()=>setShowMain(false)} />;
  else if (activeSite) screen = <CitySite site={activeSite} onBack={()=>setActiveSite(null)} />;
  else screen = <NetworkHub onSelect={setActiveSite} onMain={()=>setShowMain(true)} />;

  return (
    <div style={{ opacity:mounted?1:0,transition:"opacity .5s" }}>
      <style>{CSS}</style>
      {screen}
    </div>
  );
}
